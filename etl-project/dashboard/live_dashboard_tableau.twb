      <aliases enabled='yes' />
      <column caption='weather_pheno_extended' datatype='string' name='[Calculation_5737133388197888]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [weather_phenomenon]&#10;WHEN &quot;RA&quot; THEN &quot;Rain&quot;&#10;WHEN &quot;SHRA&quot; THEN &quot;Rain showers&quot;&#10;WHEN &quot;TS&quot; THEN &quot;Thunderstorm&quot;&#10;WHEN &quot;DZ&quot; THEN &quot;Drizzle&quot;&#10;WHEN &quot;SN&quot; THEN &quot;Snow&quot;&#10;WHEN &quot;FG&quot; THEN &quot;Fog&quot;&#10;WHEN &quot;BR&quot; THEN &quot;Mist&quot;&#10;WHEN &quot;HZ&quot; THEN &quot;Haze&quot;&#10;WHEN &quot;SA&quot; THEN &quot;Blowing sand&quot;&#10;WHEN &quot;DU&quot; THEN &quot;Widespread dust&quot;&#10;WHEN &quot;SQ&quot; THEN &quot;Squall&quot;&#10;WHEN &quot;FC&quot; THEN &quot;Funnel cloud/tornado&quot;&#10;WHEN &quot;GR&quot; THEN &quot;Hail&quot;&#10;WHEN &quot;GS&quot; THEN &quot;Small hail/snow pellets&quot;&#10;WHEN &quot;PL&quot; THEN &quot;Ice pellets&quot;&#10;WHEN &quot;VA&quot; THEN &quot;Volcanic ash&quot;&#10;ELSE [weather_phenomenon]&#10;END' />
      </column>
      <column caption='cloud_cover_extended' datatype='string' name='[Calculation_5737133388652545]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [overall_cover]&#10;WHEN &quot;SKC&quot; THEN &quot;Sky Clear&quot;&#10;WHEN &quot;CLR&quot; THEN &quot;Clear&quot;&#10;WHEN &quot;FEW&quot; THEN &quot;Few Clouds&quot;&#10;WHEN &quot;SCT&quot; THEN &quot;Scattered Clouds&quot;&#10;WHEN &quot;BKN&quot; THEN &quot;Broken Clouds&quot;&#10;WHEN &quot;OVC&quot; THEN &quot;Overcast Clouds&quot;&#10;WHEN &quot;VV&quot; THEN &quot;Vertical Visibility (Obscured Sky)&quot;&#10;ELSE [overall_cover]&#10;END' />
      </column>
      <column caption='Observed Time' datatype='datetime' name='[Calculation_6734527544504320]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[date] + ([time] - DATETRUNC(&apos;day&apos;, [time]))' />
      </column>
      <column caption='Latest Airport Time' datatype='datetime' name='[Calculation_6734527544631297]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [airport_name] : MAX([Calculation_6734527544504320]) }' />
      </column>
      <column caption='Latest Record ' datatype='boolean' name='[Calculation_6734527549161474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_6734527544504320] = [Calculation_6734527544631297]' />
      </column>
      <column caption='flight category badge' datatype='string' name='[Calculation_6734527552581636]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [flight_category]&#10;WHEN &quot;VFR&quot; THEN &quot;🟢 VFR&quot;&#10;WHEN &quot;MVFR&quot; THEN &quot;🔵 MVFR&quot;&#10;WHEN &quot;IFR&quot; THEN &quot;🔴 IFR&quot;&#10;END' />
      </column>
      <column caption='weather_hourly' datatype='table' name='[__tableau_internal_object_id__].[weather_hourly_911CFAF8936D4B59BDF211CB78D0567C]' role='measure' type='quantitative' />
